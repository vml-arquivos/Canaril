# ==========================================================================
# PRODUÇÃO - Canário Gestão Pro
# Preencha estes valores no Coolify/servidor. Não versionar segredos reais.
# ==========================================================================

DATABASE_URL="postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO"

# Gere com: openssl rand -base64 32
JWT_SECRET="troque-por-um-segredo-forte"
SESSION_SECRET="troque-por-outro-segredo-forte"
CSRF_SECRET="troque-por-um-hex-forte"

OWNER_NAME="Canário Lima"
OWNER_OPEN_ID="canario-lima-admin"
ADMIN_NAME="Canário Lima"
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="troque-esta-senha"

VITE_APP_ID="canario-gestao-pro-001"
VITE_APP_TITLE="Canário Gestão Pro"
VITE_APP_LOGO="https://canarillima.casadf.com.br/logo.png"

# OAuth é opcional. Se não usar OAuth, deixe vazio.
OAUTH_SERVER_URL=""
VITE_OAUTH_PORTAL_URL=""

PORT="3000"
LOG_LEVEL="info"
CORS_ORIGIN="https://canarillima.casadf.com.br,https://www.canarillima.casadf.com.br"
COOKIE_SECURE="true"
COOKIE_SAME_SITE="none"
COOKIE_HTTP_ONLY="true"
